# Server
PORT=3000

# Public base URL of this server (used for Twilio webhooks). e.g. https://abcd.ngrok.io
PUBLIC_BASE_URL=http://localhost:3000

# Business hours (24h local time) and default appointment length. The browser setup wizard can set these.
# These are defaults used to initialize the settings table on first run.
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=17:00
APPOINTMENT_LENGTH_MINUTES=30
TIMEZONE=America/Los_Angeles

# OpenAI (optional). Powers natural-language "route understanding" so callers
# can phrase requests freely. If unset, a built-in rule-based parser is used
# instead. You can also configure this from the dashboard Settings; environment
# values take precedence over dashboard settings.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Twilio — the PLATFORM (master) account for the whole deployment. This app is
# multi-tenant: many businesses sign up on one instance, and the platform's
# Twilio account is used to provision a dedicated phone number for each tenant
# (tenants never enter their own Twilio credentials). Set these to the master
# account SID/auth token. TWILIO_PHONE_NUMBER is only a fallback/legacy number
# for the default tenant; per-tenant numbers are assigned via the dashboard.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Validate X-Twilio-Signature on incoming voice webhooks. Set to false to
# disable (e.g. for local testing without a public tunnel).
TWILIO_VALIDATE_SIGNATURE=true

# Access control. This app is multi-tenant: businesses self-serve sign up and
# log in (session cookies), and each tenant only sees its own data. The admin
# API (/api/*) requires a logged-in session. Authentication is ENFORCED
# whenever any tenant has signed up, when NODE_ENV=production, or when
# AUTH_REQUIRED=true. It stays open only on a brand-new local/dev instance with
# no signups (convenient for local use and the test suite).
# The ADMIN_* variables below are an optional PLATFORM/operator back-compat
# path (HTTP Basic with ADMIN_USER+ADMIN_PASSWORD, or ADMIN_TOKEN for
# Bearer / ?token= access) that maps to the default tenant.
AUTH_REQUIRED=
ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_TOKEN=

# Automatic SMS appointment reminders (requires Twilio SMS configured).
REMINDERS_ENABLED=true
REMINDER_LEAD_MINUTES=60
REMINDER_POLL_SECONDS=60

# Automatic database backups (timestamped copies of the SQLite file).
BACKUPS_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP=14
# Directory for backups (defaults to <database dir>/backups).
BACKUP_DIR=

# Security hardening for public deployments. Rate limiting applies to the
# public setup and Twilio voice routes only. Set RATE_LIMIT_ENABLED=false to
# disable (e.g. for load testing).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Optional outbound email (SMTP) for password reset by email. You can also set
# this from the dashboard Settings. Environment values take precedence. SMTP_FROM
# is the address reset codes are sent from; many providers require an app
# password rather than your normal login password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Voice used by the phone assistant (Twilio text-to-speech). Defaults to a
# natural-sounding Amazon Polly Neural voice. Owners can also pick a voice from
# the dashboard Settings; this variable takes precedence when set. Examples:
# Polly.Joanna-Neural, Polly.Matthew-Neural, Polly.Amy-Neural (British).
VOICE_NAME=

# SQLite database file path
DATABASE_PATH=./data/secretary.db
