# Server
PORT=3000

# Public base URL of this server (used for Twilio webhooks). e.g. https://abcd.ngrok.io
PUBLIC_BASE_URL=http://localhost:3000

# Business hours (24h local time) and default appointment length. The browser setup wizard can set these.
# These are defaults used to initialize the settings table on first run.
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=17:00
APPOINTMENT_LENGTH_MINUTES=30
TIMEZONE=America/Los_Angeles

# OpenAI (optional). If unset, a built-in rule-based parser is used instead.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Twilio (optional here; the browser setup wizard can collect this for real phone calls).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Validate X-Twilio-Signature on incoming voice webhooks. Set to false to
# disable (e.g. for local testing without a public tunnel).
TWILIO_VALIDATE_SIGNATURE=true

# Admin protection for the dashboard/API. The browser setup wizard can create this. If neither password nor token is set,
# the API is open (convenient for local use). Basic auth uses ADMIN_USER +
# ADMIN_PASSWORD; ADMIN_TOKEN enables Bearer-token / ?token= access.
ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_TOKEN=

# Automatic SMS appointment reminders (requires Twilio SMS configured).
REMINDERS_ENABLED=true
REMINDER_LEAD_MINUTES=60
REMINDER_POLL_SECONDS=60

# Automatic database backups (timestamped copies of the SQLite file).
BACKUPS_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP=14
# Directory for backups (defaults to <database dir>/backups).
BACKUP_DIR=

# Security hardening for public deployments. Rate limiting applies to the
# public setup and Twilio voice routes only. Set RATE_LIMIT_ENABLED=false to
# disable (e.g. for load testing).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Optional outbound email (SMTP) for password reset by email. You can also set
# this from the dashboard Settings. Environment values take precedence. SMTP_FROM
# is the address reset codes are sent from; many providers require an app
# password rather than your normal login password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Voice used by the phone assistant (Twilio text-to-speech). Defaults to a
# natural-sounding Amazon Polly Neural voice. Owners can also pick a voice from
# the dashboard Settings; this variable takes precedence when set. Examples:
# Polly.Joanna-Neural, Polly.Matthew-Neural, Polly.Amy-Neural (British).
VOICE_NAME=

# SQLite database file path
DATABASE_PATH=./data/secretary.db
